---
import BaseLayout from '../layouts/BaseLayout.astro';
import { categories, flavors, menu } from '../data/menu';

// Prefix absolute asset paths with the configured base (e.g. /wings-express)
// so images resolve from the GitHub Pages project subfolder.
const withBase = (path: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + path;

const doorDashUrl = 'https://www.doordash.com/store/wings-express-little-rock-30946593/?srsltid=AfmBOoq55SyV-j7pkhVwoWXJp-aQnUzwtB5Gciemg3lUekWpGplkSc-_';
---
<BaseLayout>
  <header class="site-header">
    <div class="wide-container header-inner">
      <a class="brand" href="#top" aria-label="Wing Express home">
        <img src={withBase('/images/wing-express-logo-tight.webp')} width="240" height="194" alt="Wing Express" />
      </a>
      <nav class="desktop-nav" aria-label="Primary navigation">
        <a href="#menu">Menu</a><i></i><a href="#story">Our Story</a><i></i><a href="#location">Hours & Location</a>
      </nav>
      <a class="button button-primary header-order" href={doorDashUrl} target="_blank" rel="noreferrer">Order on DoorDash <span aria-hidden="true">★</span></a>
    </div>
  </header>

  <main id="main-content">
    <section class="hero" id="top">
      <div class="hero-copy-panel">
        <div class="hero-copy-inner">
          <span class="hero-wordmark">Wings Express</span>
          <div class="wing-rule" aria-hidden="true"><span></span><b>★</b><span></span></div>
          <h1>Flavor <span>on the fly</span></h1>
          <p class="hero-copy">Little Rock made. Bold wings, fish, tenders and sides, ready at the window.</p>
          <div class="hero-actions"><a class="text-link" href="#menu">View full menu <span aria-hidden="true">›</span></a></div>
          <div class="service-status" aria-live="polite">
            <span class="status-item"><i aria-hidden="true">◷</i><b><span data-open-label>Checking today's hours…</span><small>Tuesday–Friday</small></b></span>
            <span class="status-item"><i aria-hidden="true">◆</i><b>Browse here first<small>Order on DoorDash</small></b></span>
          </div>
        </div>
      </div>
      <div class="hero-media"><img class="hero-image" src={withBase('/images/facebook-wing-tray.jpg')} width="1536" height="2048" alt="Wing Express wings, fries, roll and ranch in front of the Wing Express sign" fetchpriority="high" /><div class="hero-stamp"><strong>Bold.</strong><strong>Local.</strong><strong>Made fresh.</strong></div></div>
    </section>

    <section class="community" id="story">
      <div class="community-grid wide-container">
        <div class="community-copy"><div class="story-stars" aria-hidden="true">★★★</div><h2>Little Rock,<br /><span>this one’s yours.</span></h2><p>Wing Express is a home-grown food truck serving bold wings and familiar favorites from the heart of Little Rock. Pull up, choose your flavor and pick it up fresh.</p><a class="button button-ghost" href="#menu">Explore the menu <span aria-hidden="true">›</span></a></div>
        <div class="community-photo"><img class="community-logo-art" src={withBase('/images/instagram-logo-cropped.jpg')} width="1440" height="1220" alt="Wing Express — Flavor on the Fly" loading="lazy" /></div>
        <div class="location-panel" id="location"><div class="location-heading"><span aria-hidden="true">●</span><h3><a class="address-link" href="https://maps.apple/p/b.vL8N_t9YBvW9" target="_blank" rel="noreferrer">219 S. Cross St.<br />Little Rock, AR</a></h3></div><ul class="hours-list"><li><strong>Tue–Fri</strong><span class="hours-range"><span>11:30 AM–2:30 PM</span><span>4:00–7:00 PM</span></span></li><li><strong>Sat</strong><span>12:00–2:40 PM</span></li><li><strong>Sun–Mon</strong><span>Closed</span></li></ul><a class="button button-secondary" href="https://maps.apple/p/b.vL8N_t9YBvW9" target="_blank" rel="noreferrer">Get directions</a></div>
      </div>
    </section>

    <section class="menu-section" id="menu">
      <div class="container">
        <div class="section-heading"><div><h2>Know your order.</h2><p>Browse current selections and prices here, then use the DoorDash button in the header to customize, check availability and pay.</p></div></div>
        <div class="category-tabs" role="tablist" aria-label="Menu categories">
          {categories.map((category, index) => <button class="category-tab" role="tab" aria-selected={index === 0 ? 'true' : 'false'} data-category={category.id}>{category.label}</button>)}
        </div>
        <div class="menu-layout">
          <div class="menu-list" aria-live="polite">
            {menu.map((item) => (
              <article class="menu-item" data-menu-item={item.id} data-category-item={item.category} hidden={item.category !== 'combos'}>
                <div><h3>{item.name}</h3><p>{item.description}</p><span class="sold-label" hidden>Sold out</span></div>
                <span class="price">${item.price}</span>
              </article>
            ))}
          </div>
          <aside class="flavor-board">
            <h3>Flavor board</h3>
            <div class="flavor-columns"><div><strong>Wet</strong><ul>{flavors.wet.map((flavor) => <li>{flavor}</li>)}</ul></div><div><strong>Dry</strong><ul>{flavors.dry.map((flavor) => <li>{flavor}</li>)}</ul></div></div>
          </aside>
        </div>
      </div>
    </section>

    <section class="socials" aria-labelledby="socials-title">
      <div class="container">
        <div class="section-heading"><div><h2 id="socials-title">Follow us on socials.</h2><p>Tap in for fresh food, events and updates from Wing Express.</p></div></div>
        <div class="social-grid">
          <a class="social-card" href="https://www.instagram.com/wingsexpress.lr/" target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            <strong>Instagram</strong>
            <span class="social-handle">@wingsexpress.lr</span>
          </a>
          <a class="social-card" href="https://www.facebook.com/people/Wing-Express/61557021123961/?checkpoint_src=any" target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            <strong>Facebook</strong>
            <span class="social-handle">Wing Express</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer"><div class="container footer-grid"><img class="footer-logo" src={withBase('/images/wing-express-logo-tight.webp')} alt="" /><div><strong>Wing Express</strong><p>Home-grown wings, fish, tenders and sides in Little Rock.</p></div><div><a href="#menu">View menu</a><br /><a href="#location">Hours and directions</a><br /><a href="https://www.instagram.com/wingsexpress.lr/">Instagram</a><br /><a href="https://www.facebook.com/people/Wing-Express/61557021123961/?checkpoint_src=any">Facebook</a></div></div></footer>

  <script is:inline>
    // @ts-nocheck
    const $ = (selector, root = document) => root.querySelector(selector);
    const $$ = (selector, root = document) => [...root.querySelectorAll(selector)];
    $$('[data-category]').forEach((tab) => tab.addEventListener('click', () => {
      $$('[data-category]').forEach((other) => other.setAttribute('aria-selected', String(other === tab)));
      $$('[data-category-item]').forEach((item) => item.hidden = item.dataset.categoryItem !== tab.dataset.category);
    }));
    // Static site: no live backend, so show the standing hours label and keep the
    // built-in Instagram empty state already rendered in the markup above.
    $('[data-open-label]').textContent = 'See today’s hours';
  </script>
</BaseLayout>
